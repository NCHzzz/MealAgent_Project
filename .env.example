# MealAgent / Elysia local development environment.
# Copy to .env and fill only the values you need. Never commit real secrets.

# Backend runtime
BASE_MODEL=gemini-2.0-flash-001
BASE_PROVIDER=openrouter/google
COMPLEX_MODEL=gemini-2.5-flash
COMPLEX_PROVIDER=openrouter/google
USE_MEAL_AGENT_TREE=true
LOGGING_LEVEL=INFO

# Browser/CORS allowlist for the FastAPI backend.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=true

# Local Weaviate from Docker/docker-compose.yml
WEAVIATE_IS_LOCAL=True
LOCAL_WEAVIATE_PORT=8078
LOCAL_WEAVIATE_GRPC_PORT=50051

# Weaviate Cloud fallback. Leave blank for local Docker.
WCD_URL=
WCD_API_KEY=

# LLM/API providers. Fill at least one provider used by BASE_PROVIDER/COMPLEX_PROVIDER.
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional backend timeouts, in minutes.
CLIENT_TIMEOUT=3
TREE_TIMEOUT=10
USER_TIMEOUT=20
